# ============================================================
#  RegistroPQRS v1 — Plantilla de Variables de Entorno
#  Copiar este archivo como .env y completar los valores reales
#    cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# ENTORNO
# ----------------------------------------------------------
APP_NAME="RegistroPQRS"
APP_ENV=local
APP_DEBUG=false
BASE_URL=http://localhost/RegistroPQRS/

# ----------------------------------------------------------
# BASE DE DATOS
# ----------------------------------------------------------
DB_HOST=localhost
DB_NAME=mesadepartes
DB_USER=root
DB_PASS=

# ----------------------------------------------------------
# SEGURIDAD — CIFRADO AES-256-CBC
# Generar una clave segura: openssl rand -base64 32
# ADVERTENCIA: cambiar esta clave invalida todos los passwords
# ----------------------------------------------------------
AES_KEY=your_aes_secret_key_min_16_chars
AES_CIPHER=aes-256-cbc

# ----------------------------------------------------------
# EMAIL — SMTP Gmail
# Generar App Password en: myaccount.google.com/apppasswords
# Requiere verificación en 2 pasos activada en Google
# ----------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM_NAME="RegistroPQRS"

# ----------------------------------------------------------
# GOOGLE OAUTH 2.0
# Obtener en: console.cloud.google.com → Credentials
# ----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
